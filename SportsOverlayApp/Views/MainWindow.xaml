<Window x:Class="SportsOverlayApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sports Overlay" Height="40"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        ShowActivated="False" Focusable="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <ItemsPanelTemplate x:Key="HorizontalPanel">
            <StackPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- Dark tooltips: the default light ones are unreadable over the
             taskbar (used e.g. for the full F1 classification on hover). -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#F2181820"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Team/participant crest or nationality flag shown next to team/player
             names. Visibility is driven per-instance by a DataTrigger on the
             bound URL (see usages). -->
        <Style x:Key="LogoImage" TargetType="Image">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="PillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#D9181820"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FlatButton" TargetType="ButtonBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border Background="Transparent" Padding="4,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ChipTemplate">
            <Border CornerRadius="6" Margin="2,4" Padding="7,2" VerticalAlignment="Center"
                    ToolTip="{Binding RankingTooltip}" ToolTipService.ShowDuration="60000">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="#26FFFFFF"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Silent goal cue: hold the tennis-points green while
                                 JustScored is on, then fade back to normal. -->
                            <DataTrigger Binding="{Binding JustScored}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#E62E7D32" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#26FFFFFF" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="★" FontSize="10" Foreground="#FFFFD54F" Margin="0,0,3,0"
                               VerticalAlignment="Center" ToolTip="Recommended for you"
                               Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding SportIcon}" FontSize="12" Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                    <Image Source="{Binding HomeLogoUrl}">
                        <Image.Style>
                            <Style TargetType="Image" BasedOn="{StaticResource LogoImage}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HomeLogoUrl}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Image Source="{Binding HomeFlag}">
                        <Image.Style>
                            <Style TargetType="Image" BasedOn="{StaticResource LogoImage}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HomeFlag}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="{Binding HomeTeam}" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="●" FontSize="10" Foreground="#FFFFD54F" Margin="3,0,0,0"
                               VerticalAlignment="Center" ToolTip="Serving"
                               Visibility="{Binding ServingHome, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding Score}" FontSize="12" FontWeight="Bold"
                               Foreground="#FFD54F" Margin="6,0" VerticalAlignment="Center"/>
                    <Image Source="{Binding AwayLogoUrl}">
                        <Image.Style>
                            <Style TargetType="Image" BasedOn="{StaticResource LogoImage}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AwayLogoUrl}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Image Source="{Binding AwayFlag}">
                        <Image.Style>
                            <Style TargetType="Image" BasedOn="{StaticResource LogoImage}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AwayFlag}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="{Binding AwayTeam}" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="●" FontSize="10" Foreground="#FFFFD54F" Margin="3,0,0,0"
                               VerticalAlignment="Center" ToolTip="Serving"
                               Visibility="{Binding ServingAway, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding PartsDisplay}" FontSize="12" FontWeight="Bold"
                               Foreground="#FFDCEBFA" Margin="6,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PartsDisplay}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- 2nd/3rd place for ranking events (F1...): name in white,
                         gap-to-leader time in red. -->
                    <ItemsControl ItemsSource="{Binding RankingGaps}"
                                  ItemsPanel="{StaticResource HorizontalPanel}" Margin="6,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                    <Image Source="{Binding Flag}">
                                        <Image.Style>
                                            <Style TargetType="Image" BasedOn="{StaticResource LogoImage}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Flag}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FFDCEBFA" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Time}" FontSize="12" FontWeight="Bold"
                                               Foreground="#FFEF5350" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border CornerRadius="4" Padding="5,0" Margin="6,1" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E62E7D32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PointsDisplay}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding PointsDisplay}" FontSize="12" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding Time}" FontSize="10" Margin="5,0,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLive}" Value="True">
                                        <Setter Property="Foreground" Value="#EF5350"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="✕" FontSize="10" Margin="4,0,0,0" Style="{StaticResource FlatButton}"
                            Visibility="{Binding IsFinished, Converter={StaticResource BoolToVis}}"
                            Click="Dismiss_Click" ToolTip="Remove finished game"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- The window spans the whole taskbar width; everything outside the pills is
         fully transparent, so clicks there fall through to the taskbar icons. -->
    <Grid>
        <StackPanel x:Name="LeftGroup" Orientation="Horizontal"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
            <Border x:Name="LeftPill" Style="{StaticResource PillStyle}"
                    MouseLeftButtonDown="Pill_MouseDown" MouseMove="Pill_MouseMove"
                    MouseLeftButtonUp="Pill_MouseUp" Tag="left">
                <ItemsControl x:Name="LeftList" Margin="6,0"
                              ItemTemplate="{StaticResource ChipTemplate}"
                              ItemsPanel="{StaticResource HorizontalPanel}"/>
            </Border>
        </StackPanel>

        <StackPanel x:Name="RightGroup" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
            <Border x:Name="RightPill" Style="{StaticResource PillStyle}" Margin="0,0,6,0"
                    MouseLeftButtonDown="Pill_MouseDown" MouseMove="Pill_MouseMove"
                    MouseLeftButtonUp="Pill_MouseUp" Tag="right">
                <ItemsControl x:Name="RightList" Margin="6,0"
                              ItemTemplate="{StaticResource ChipTemplate}"
                              ItemsPanel="{StaticResource HorizontalPanel}"/>
            </Border>
            <Border x:Name="ControlPill" Style="{StaticResource PillStyle}" Padding="6,2"
                    MouseLeftButtonDown="Pill_MouseDown" MouseMove="Pill_MouseMove"
                    MouseLeftButtonUp="Pill_MouseUp" Tag="right">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="OverflowToggle" Content="^" FontSize="12" FontWeight="Bold"
                                  Style="{StaticResource FlatButton}" Visibility="Collapsed"
                                  ToolTip="Choose which games are shown"/>
                    <Ellipse x:Name="ConnectionDot" Width="9" Height="9" Fill="#E53935" Margin="4,0"/>
                    <TextBlock x:Name="ConnectionLabel" Text="offline" FontSize="10"
                               Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="2,0,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Popup x:Name="OverflowPopup" Placement="Top" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=OverflowToggle}"
               IsOpen="{Binding IsChecked, ElementName=OverflowToggle, Mode=TwoWay}">
            <Border x:Name="PopupPill" Style="{StaticResource PillStyle}" Padding="10,8" Margin="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="Shown on the bar:" FontSize="11" Foreground="#AAFFFFFF" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="PickerList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <ToggleButton IsChecked="{Binding IsLiked, Mode=OneWay}" Click="Like_Click"
                                                  FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"
                                                  ToolTip="Like this game: after a few days the app recommends similar games (★)">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton" BasedOn="{StaticResource FlatButton}">
                                                <Setter Property="Content" Value="♡"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="♥"/>
                                                        <Setter Property="Foreground" Value="#EF5350"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <CheckBox IsChecked="{Binding IsShown, Mode=OneWay}" Click="PickerItem_Click"
                                              Foreground="White" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Summary}" FontSize="12"/>
                                    </CheckBox>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel x:Name="RecommendedSection" Visibility="Collapsed">
                        <Border Height="1" Background="#22FFFFFF" Margin="0,8"/>
                        <TextBlock Text="★ Recommended for you:" FontSize="11"
                                   Foreground="#FFFFD54F" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="RecommendedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <ToggleButton IsChecked="{Binding IsLiked, Mode=OneWay}" Click="Like_Click"
                                                      FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"
                                                      ToolTip="Like this game to keep recommending it">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource FlatButton}">
                                                    <Setter Property="Content" Value="♡"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Content" Value="♥"/>
                                                            <Setter Property="Foreground" Value="#EF5350"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                        <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="✕" Click="Dismiss_Click" Style="{StaticResource FlatButton}"
                                                FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"
                                                Foreground="#88FFFFFF" ToolTip="Not interested"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
