<Window x:Class="SportsOverlayApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sports Overlay" Height="200" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" Topmost="True">
    <Grid x:Name="OverlayGrid" Background="Transparent">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="MatchTitle" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="Score" FontSize="30" HorizontalAlignment="Center"/>
            <TextBlock x:Name="Status" FontSize="14" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
