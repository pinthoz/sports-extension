<Window x:Class="SportsOverlayApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="400">
    <StackPanel Margin="20">
        <TextBlock Text="Favorite Team:"/>
        <TextBox x:Name="TeamSelector"/>

        <CheckBox x:Name="DarkModeToggle" Content="Use Dark Theme"/>
        <TextBlock Text="Overlay Opacity:"/>
        <Slider x:Name="OpacitySlider" Minimum="10" Maximum="100"/>

        <CheckBox x:Name="NotificationsToggle" Content="Enable Notifications"/>
        <CheckBox x:Name="AutoHideToggle" Content="Auto Hide Overlay"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
