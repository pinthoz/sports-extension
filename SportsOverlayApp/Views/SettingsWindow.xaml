<Window x:Class="SportsOverlayApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sports Overlay: Settings" Height="460" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FF1E1E26">
    <StackPanel Margin="24">
        <TextBlock Text="Data source:" Foreground="White"/>
        <ComboBox x:Name="SourceSelector" Margin="0,4,0,12">
            <ComboBoxItem Content="Built-in FlashScore (no browser tab needed)"/>
            <ComboBoxItem Content="Browser extension (WebSocket)"/>
        </ComboBox>

        <TextBlock Text="Bar position:" Foreground="White"/>
        <ComboBox x:Name="PositionSelector" Margin="0,4,0,12">
            <ComboBoxItem Content="Bottom (above taskbar)"/>
            <ComboBoxItem Content="Top of screen"/>
            <ComboBoxItem Content="On the taskbar (compact, drag to place)"/>
        </ComboBox>

        <CheckBox x:Name="DarkModeToggle" Content="Use dark theme" Foreground="White" Margin="0,0,0,8"/>

        <TextBlock Text="Bar opacity:" Foreground="White"/>
        <Slider x:Name="OpacitySlider" Minimum="30" Maximum="100" Margin="0,4,0,12"
                TickFrequency="5" IsSnapToTickEnabled="True"/>

        <CheckBox x:Name="NotificationsToggle" Content="Goal notifications (sound)" Foreground="White" Margin="0,0,0,8"/>
        <CheckBox x:Name="StartupToggle" Content="Start with Windows" Foreground="White" Margin="0,0,0,12"/>

        <TextBlock Text="WebSocket port (must match the extension popup):" Foreground="White"/>
        <TextBox x:Name="PortInput" Margin="0,4,0,12" Width="100" HorizontalAlignment="Left"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
